# ==================== Server ====================
# Base path the API is mounted under. Leave empty to serve at "/".
RD_API_PATH=
RD_INTERNAL_PORT=8000
RD_LOG_PATH=./logs/app.log
RD_LOG_LEVEL=INFO
RD_RUN_MODE=local
RD_WORKERS=1
RD_STARTUP_TIMEOUT=60

OMP_THREAD_LIMIT=1
REQ_PARALLELISM=2

# ==================== Layout inference (ONNX) ====================
# Comma-separated layout model ids to load. Each maps to
# ${LAYOUT_MODEL_DIR}/RT-DETR_<id>.onnx
MODEL_LIST=25
MODEL_ID=25
LAYOUT_MODEL_DIR=./layout_model
RUNTIME_BACKEND=ONNX
BACKEND_THREADS=2
CONFIDENCE_THTRESHOLD_25=0.3

# ==================== Local image storage ====================
LOCAL_IMAGE_DIR=./output_images
STATIC_URL_PREFIX=/static
PUBLIC_BASE_URL=http://127.0.0.1:8000
UPLOAD_PREFIX=
PDF_RENDER_DPI=150

# ==================== Gradio (standalone UI) ====================
GRADIO_HOST=0.0.0.0
GRADIO_PORT=7860

# ==================== OCR backend (MOSS) ====================
# OpenAI-compatible endpoint serving the MOSS-OCR model.
# Deploy the model with vLLM, then point this at /v1.
# Model: https://github.com/patsnap/Hiro-MOSS-OCR
MOSS_VLLM_OCR_API=http://127.0.0.1:8088/v1
MOSS_VLLM_OCR_API_KEY=EMPTY
MOSS_VLLM_MODEL=moss-v1d6-0.3b
MOSS_VLLM_OCR_MAX_CONCURRENT=32

# ==================== Document conversion (optional) ====================
# Converting Office documents (doc/docx/ppt/xls/...) to PDF requires a running
# LibreOffice unoserver. Leave disabled if you only process PDFs and images.
DOCUMENT_CONVERT_ENABLED=false
UNOSERVER_ENDPOINTS=127.0.0.1:2003
DOCUMENT_CONVERT_TIMEOUT=60
DOCUMENT_CONVERT_MAX_BYTES=52428800
DOCUMENT_CONVERT_MAX_CONCURRENCY=2
